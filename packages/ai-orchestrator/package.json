{
  "name": "@super-ai/ai-orchestrator",
  "version": "0.1.0",
  "description": "Production-grade AI Orchestration Framework — core library",
  "private": true,
  "main": "./dist/index.js",
  "types": "./dist/index.d.ts",
  "exports": {
    ".": {
      "import": "./dist/index.js",
      "require": "./dist/index.js",
      "types": "./dist/index.d.ts"
    },
    "./core": {
      "import": "./dist/core/index.js",
      "require": "./dist/core/index.js",
      "types": "./dist/core/index.d.ts"
    },
    "./shared": {
      "import": "./dist/shared/index.js",
      "require": "./dist/shared/index.js",
      "types": "./dist/shared/index.d.ts"
    }
  },
  "scripts": {
    "build": "tsc --project tsconfig.json",
    "typecheck": "tsc --noEmit",
    "test": "jest --config jest.config.js --passWithNoTests",
    "test:coverage": "jest --config jest.config.js --coverage --passWithNoTests",
    "clean": "rimraf dist"
  },
  "devDependencies": {
    "@types/jest": "^29.5.12",
    "@types/node": "^20.8.0",
    "jest": "^29.7.0",
    "rimraf": "^5.0.5",
    "ts-jest": "^29.1.4",
    "typescript": "^5.2.2"
  }
}
